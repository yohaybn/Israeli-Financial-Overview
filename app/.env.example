# Port to listen on (default 3000)
PORT=3000

# Path to the Google Cloud Service Account JSON file (inside the container)
SERVICE_ACCOUNT_PATH=./service-account.json

# ID of the Google Drive folder to upload to
DRIVE_FOLDER_ID=your_drive_folder_id_here

# Secret key for encrypting sensitive data (e.g. AI API keys)
APP_SECRET=your_app_secret_here

# (Optional) JSON string to override settings.json
# SETTINGS_JSON={"appSecret": "...", "ai": {"autoRun": true, "model": "..."}}

