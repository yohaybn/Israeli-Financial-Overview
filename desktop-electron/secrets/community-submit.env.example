# Copy to community-submit.env (same folder) and fill the secret. Do not commit community-submit.env.
# Before electron-builder, copy secrets/community-submit.env into your staged package, e.g.:
#   dist/windows-package/secrets/community-submit.env   (Windows)
#   dist/macos-package/secrets/community-submit.env     (macOS)
# so it ends up next to server/ under the app resources folder.
#
# Same value as Google Apps Script property AUTH_SECRET.

COMMUNITY_INSIGHT_RULES_SECRET=

# Optional — only if you use a different Apps Script deployment than the server default:
# COMMUNITY_INSIGHT_RULES_GAS_URL=
