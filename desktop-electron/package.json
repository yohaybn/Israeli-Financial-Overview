{
    "name": "financial-overview-desktop",
    "version": "1.0.0",
    "description": "Financial Overview desktop shell (Electron)",
    "author": "Financial Overview",
    "private": true,
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "predist": "node scripts/clean-electron-dist.cjs",
        "dist": "electron-builder --win",
        "dist:mac": "electron-builder --mac -c.directories.output=../dist/electron-mac"
    },
    "dependencies": {
        "electron-store": "^8.2.0"
    },
    "devDependencies": {
        "electron": "33.2.1",
        "electron-builder": "^25.1.8"
    },
    "build": {
        "electronVersion": "33.2.1",
        "appId": "com.financialoverview.desktop",
        "productName": "Financial Overview",
        "executableName": "FinancialOverview",
        "directories": {
            "output": "../dist/electron-win"
        },
        "files": [
            "main.js",
            "preload.js"
        ],
        "win": {
            "extraResources": [
                {
                    "from": "../dist/windows-package",
                    "to": ".",
                    "filter": [
                        "**/*"
                    ]
                }
            ],
            "artifactName": "FinancialOverview-Windows-Setup-${version}.${ext}",
            "sign": null,
            "signAndEditExecutable": false,
            "target": [
                {
                    "target": "dir",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "../client/public/favicon.ico"
        },
        "mac": {
            "extraResources": [
                {
                    "from": "../dist/macos-package",
                    "to": ".",
                    "filter": [
                        "**/*"
                    ]
                }
            ],
            "artifactName": "FinancialOverview-Mac-${version}.${ext}",
            "category": "public.app-category.finance",
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "arm64"
                    ]
                },
                {
                    "target": "zip",
                    "arch": [
                        "arm64"
                    ]
                }
            ],
            "identity": null,
            "hardenedRuntime": false,
            "gatekeeperAssess": false,
            "icon": "../client/public/favicon.ico"
        },
        "dmg": {
            "sign": false
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "shortcutName": "Financial Overview"
        }
    }
}
