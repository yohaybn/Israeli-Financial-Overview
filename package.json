{
    "name": "israeli-bank-scraper-monorepo",
    "private": true,
    "workspaces": [
        "shared",
        "server",
        "client"
    ],
    "scripts": {
        "setup": "npm install && npm run build -w shared",
        "server": "npm run dev -w server",
        "client": "npm run dev -w client",
        "dev": "npx concurrently \"npm run server\" \"npm run client\"",
        "kill-port": "powershell ./kill-port.ps1",
        "start": "npm run dev",
        "video-guide:capture": "node scripts/capture-video-guide-media.mjs",
        "video-guide:capture-configs": "node scripts/capture-video-guide-media.mjs --only-configs",
        "windows:package": "powershell -ExecutionPolicy Bypass -File packaging/windows/package.ps1"
    },
    "devDependencies": {
        "concurrently": "^8.2.2",
        "playwright": "^1.49.1"
    }
}
